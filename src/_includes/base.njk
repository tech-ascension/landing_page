    <link
      rel="stylesheet"
      href="https://pro.fontawesome.com/releases/v5.10.0/css/all.css"
      integrity="sha384-AYmEC3Yw5cVb3ZcuHtOA93w35dYTsvhLPVnYs9eStHfGJvOvKxVfELGroGkvsg+p"
      crossorigin="anonymous"/>
    <title>
      {{ title }}
    </title>
  </head>
  <body class="flex flex-col min-h-screen bg-black text-foreground font-body">
    {% include 'header.njk' %}
    <main class="flex-1">
      {{ content | safe }}
    </main>
    {% include 'about-contact-card.njk' %}
    {% include 'footer.njk' %}
    <script>
      if (window.netlifyIdentity) {
        window
          .netlifyIdentity
          .on('init', (user) => {
            if (!user) {
              window
                .netlifyIdentity
                .on('login', () => {
                  document.location.href = '/admin/';
                });
            }
          });
      }
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Snap-scroll on arrow click
        var scrollBtn = document.getElementById('scroll-down-btn');
        if (scrollBtn) {
          scrollBtn.addEventListener('click', function () {
            var target = document.getElementById('portfolio');
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          });
        }

        // === Hero video load → wipe loader to reveal video ===
        console.time('hero-total');
        console.time('hero-video-ready');
        var video = document.getElementById('hero-video');
        var loader = document.getElementById('hero-loader');
        var hero = document.getElementById('hero');

        console.log('[hero] DOMContentLoaded, video.readyState:', video ? video.readyState : 'N/A');

        function startHeroTransition() {
          if (hero.classList.contains('hero-loaded') || loader.classList.contains('is-wiping')) return;
          console.timeEnd('hero-video-ready');
          console.time('hero-wipe');
          console.log('[hero] Starting wipe transition');
          loader.classList.add('is-wiping');
          loader.addEventListener('animationend', function () {
            loader.classList.add('is-hidden');
            hero.classList.add('hero-loaded');
            console.timeEnd('hero-wipe');
            console.timeEnd('hero-total');
          }, { once: true });
        }

        if (video) {
          // Use 'playing' event — guarantees video has actually started rendering
          if (video.readyState >= 4 && !video.paused) {
            console.log('[hero] Video already playing at DOMContentLoaded');
            startHeroTransition();
          } else {
            console.log('[hero] Waiting for video to start playing...');
            video.addEventListener('playing', function () {
              console.log('[hero] Video "playing" event fired');
              startHeroTransition();
            }, { once: true });
          }
          // Safety fallback — don't leave loader forever
          setTimeout(function () {
            console.log('[hero] Safety fallback triggered');
            startHeroTransition();
          }, 6000);
        }

        // Scroll-reveal with IntersectionObserver
        var reveals = document.querySelectorAll('.reveal');
        if (reveals.length && 'IntersectionObserver' in window) {
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          }, {
            threshold: 0.1,
            rootMargin: '0px 0px -40px 0px'
          });
          reveals.forEach(function (el) {
            observer.observe(el);
          });
        } else {
          // Fallback: show everything
          reveals.forEach(function (el) {
            el.classList.add('is-visible');
          });
        }
      });
    </script>
  </body>
</html>
