<header class="fixed top-0 z-50 w-full bg-black/90 backdrop-blur-sm border-b border-border">
    <div class="container flex items-center justify-between px-5 py-4 mx-auto">
        <a href="/">
            <img class="h-12 lg:hidden" src="/assets/images/logo-icon.svg" alt="Ascension Cloud Solutions"/>
            <img class="hidden lg:block h-10" src="/assets/images/logo.svg" alt="Ascension Cloud Solutions"/>
        </a>
        <button class="lg:hidden" onclick="openHeader()">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-8 h-8 text-foreground"
                id="header-bars">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
            </svg>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="hidden w-8 h-8 text-foreground"
                id="header-xmark">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
        <ul class="absolute left-0 z-50 flex flex-col items-center w-full h-0 gap-8 py-0 overflow-hidden text-sm font-medium
                transition-all duration-300 bg-black text-foreground navbar-links lg:py-0 rounded-b-xl lg:w-fit lg:flex-row
                lg:bg-transparent lg:gap-8 top-full lg:flex lg:relative lg:h-auto lg:overflow-visible">
            <li>
                <a href="/" class="transition-opacity hover:opacity-60">Home</a>
            </li>
            <li>
                <a href="/#services" class="transition-opacity hover:opacity-60">Services</a>
            </li>
            <li>
                <a href="/#about" class="transition-opacity hover:opacity-60">About Us</a>
            </li>
            <li>
                <a href="/#vision" class="transition-opacity hover:opacity-60">Our Vision</a>
            </li>
            <li>
                <a href="/blog" class="transition-opacity hover:opacity-60">Blog</a>
            </li>
            <li>
                <button class="px-5 py-2 text-sm font-medium transition-all border rounded-full no-smoothState open-contact border-primary text-primary hover:bg-primary hover:text-black">Contact</button>
            </li>
        </ul>
    </div>
</header>
<script>
    const openHeader = () => {
        const nav = document.querySelector('.navbar-links');
        const main = document.querySelector('main');
        const bars = document.querySelector('header #header-bars');
        const xmark = document.querySelector('header #header-xmark');
        nav.classList.toggle('py-0');
        nav.classList.toggle('py-12');
        nav.classList.toggle('h-0');
        main.classList.toggle('opacity-5');
        bars.classList.toggle('hidden');
        xmark.classList.toggle('hidden');
    }
</script>
