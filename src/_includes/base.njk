  <body class="flex flex-col min-h-screen bg-black text-foreground font-body">
    <div class="page-transition" id="page-transition"></div>
    {% include 'header.njk' %}
    <main class="flex-1">
      {{ content | safe }}
    </main>
    {% include 'about-contact-card.njk' %}
    {% include 'footer.njk' %}
    <script>
      if (window.netlifyIdentity) {
        window
          .netlifyIdentity
          .on('init', (user) => {
            if (!user) {
              window
                .netlifyIdentity
                .on('login', () => {
                  document.location.href = '/admin/';
                });
            }
          });
      }
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Snap-scroll on arrow click
        var scrollBtn = document.getElementById('scroll-down-btn');
        if (scrollBtn) {
          scrollBtn.addEventListener('click', function () {
            var target = document.getElementById('portfolio');
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          });
        }

        // === Hero YouTube iframe load → wipe loader to reveal video ===
        console.time('hero-total');
        console.time('hero-video-ready');
        var iframe = document.getElementById('hero-video');
        var loader = document.getElementById('hero-loader');
        var hero = document.getElementById('hero');

        function startHeroTransition() {
          if (hero.classList.contains('hero-loaded') || loader.classList.contains('is-wiping')) return;
          console.timeEnd('hero-video-ready');
          console.time('hero-wipe');
          console.log('[hero] Starting wipe transition');
          loader.classList.add('is-wiping');
          loader.addEventListener('animationend', function () {
            loader.classList.add('is-hidden');
            hero.classList.add('hero-loaded');
            console.timeEnd('hero-wipe');
            console.timeEnd('hero-total');
          }, { once: true });
        }

        if (iframe) {
          // YouTube iframe API — listen for player state changes
          var tag = document.createElement('script');
          tag.src = 'https://www.youtube.com/iframe_api';
          document.head.appendChild(tag);

          window.onYouTubeIframeAPIReady = function () {
            var player = new YT.Player('hero-video', {
              events: {
                onStateChange: function (event) {
                  if (event.data === YT.PlayerState.PLAYING) {
                    console.log('[hero] YouTube player started playing');
                    startHeroTransition();
                  }
                }
              }
            });
          };

          // Safety fallback — don't leave loader forever
          setTimeout(function () {
            console.log('[hero] Safety fallback triggered');
            startHeroTransition();
          }, 6000);
        }

        // Scroll-reveal with IntersectionObserver
        var reveals = document.querySelectorAll('.reveal');
        if (reveals.length && 'IntersectionObserver' in window) {
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          }, {
            threshold: 0.1,
            rootMargin: '0px 0px -40px 0px'
          });
          reveals.forEach(function (el) {
            observer.observe(el);
          });
        } else {
          // Fallback: show everything
          reveals.forEach(function (el) {
            el.classList.add('is-visible');
          });
        }
      });
    </script>
    <script>
      (function () {
        var transition = document.getElementById('page-transition');
        if (!transition) return;

        // On page load: if we arrived via a page transition, wipe out to reveal
        if (sessionStorage.getItem('page-transition')) {
          sessionStorage.removeItem('page-transition');
          transition.style.clipPath = 'inset(0 0 0 0)';
          // Small delay to ensure the page has painted
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              transition.classList.add('wipe-out');
              transition.addEventListener('animationend', function () {
                transition.classList.remove('wipe-out');
                transition.style.clipPath = '';
              }, { once: true });
            });
          });
        }

        // Intercept internal navigation links
        document.addEventListener('click', function (e) {
          var link = e.target.closest('a[href]');
          if (!link) return;

          var href = link.getAttribute('href');
          // Skip: external links, anchors on same page, open-contact, javascript:, #
          if (!href ||
              href.startsWith('#') ||
              href.startsWith('javascript') ||
              href.startsWith('http') ||
              href.startsWith('mailto') ||
              link.target === '_blank' ||
              link.classList.contains('no-smoothState') ||
              link.classList.contains('open-contact')) return;

          // Handle same-page hash links with JS smooth scroll (prevents flicker)
          var currentPath = window.location.pathname.replace(/\/$/, '') || '/';
          var linkPath = href.split('#')[0].replace(/\/$/, '') || '/';
          if (currentPath === linkPath) {
            var hash = href.split('#')[1];
            if (hash) {
              e.preventDefault();
              var target = document.getElementById(hash);
              if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                history.pushState(null, '', '#' + hash);
              }
            }
            return;
          }

          e.preventDefault();
          sessionStorage.setItem('page-transition', '1');
          transition.classList.add('wipe-in');
          transition.addEventListener('animationend', function () {
            window.location.href = href;
          }, { once: true });
        });
      })();
    </script>
  </body>
</html>
