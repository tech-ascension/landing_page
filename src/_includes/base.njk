      !(function (c, h, i, m, p) {
        (m = c.createElement(h)),
        (p = c.getElementsByTagName(h)[0]),
        (m.async = 1),
        (m.src = i),
        p
          .parentNode
          .insertBefore(m, p);
      })(document, 'script', 'https://chimpstatic.com/mcjs-connected/js/users/2e33e53404e6e2528bc8e75f5/494e93923ee1e02207a4ecdf9.js',);
